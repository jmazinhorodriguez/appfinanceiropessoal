{
  "name": "finance-os-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=finance-os-web",
    "build": "npm run build --workspace=finance-os-web",
